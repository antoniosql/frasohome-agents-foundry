# Required for live Foundry calls.
# Format: https://<resource>.services.ai.azure.com/api/projects/<project>
PROJECT_ENDPOINT=

# Name of a model deployment available in your Microsoft Foundry project.
MODEL_DEPLOYMENT=gpt-5-mini

# Optional: existing vector store containing the Markdown case and KB files.
# If blank, create-agents will try to create/upload one through the installed SDK.
FRASOHOME_VECTOR_STORE_ID=

# Agent names.
FRASOHOME_KNOWLEDGE_AGENT=frasohome-knowledge
FRASOHOME_DATA_QUALITY_AGENT=frasohome-data-quality
FRASOHOME_RETURNS_AGENT=frasohome-returns
FRASOHOME_OPERATIONS_AGENT=frasohome-operations
FRASOHOME_STORYTELLER_AGENT=frasohome-storyteller

# Local paths.
FRASOHOME_CASE_DIR=case
FRASOHOME_OUTPUT_DIR=outputs

# Demo behavior.
FRASOHOME_CONFIDENCE_THRESHOLD=0.75
